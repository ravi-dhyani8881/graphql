extend type Query {
 finduserByQuery(query: String, start: String, rows: String, filterField: String, filterQuery: [String], sort: String, advanceField: String, advanceQuery: String, advance: String): userResponse
}

type userResponse {
  data: [Recordsuser]
  pagination: Pagination
  advanced: [Advanced]
}
     
type Recordsuser {
ID: String
password: String
email: String

}