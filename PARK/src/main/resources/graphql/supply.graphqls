extend type Query {
 findsupplyByQuery(query: String, start: String, rows: String, filterField: String, filterQuery: [String], sort: String, advanceField: String, advanceQuery: String, advance: String): supplyResponse
}

type supplyResponse {
  data: [Recordssupply]
  pagination: Pagination
  advanced: [Advanced]
}
     
type Recordssupply {
ID: String
supplyId: String

}